# Required for /api/inquiry email delivery through SendGrid.
# Set real values in .env.local for local testing and in Vercel Production.
# Do not commit real API keys or local env files.
CONTACT_TO_EMAIL=exporter@justhen.co.jp
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Optional production-only analytics and site verification.
# Set real values in Vercel Production. Analytics tags do not run on localhost.
GA_MEASUREMENT_ID=
GOOGLE_SITE_VERIFICATION=
CLARITY_PROJECT_ID=
